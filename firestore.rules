rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) 
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId}/favorites/{favoriteId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(favoriteId);
      allow delete: if isOwner(userId);
    }
  }
}
