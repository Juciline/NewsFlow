rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['displayName', 'email', 'updatedAt']) &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }

      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.keys().hasAll(['createdAt']) &&
                      request.resource.data.createdAt == request.time;
                      
      allow update: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.updatedAt == request.time &&
                      request.resource.data.diff(resource.data).affectedKeys().hasAny(['preferences', 'displayName', 'updatedAt', 'email']);
    }

    // --- Favorites Rules ---
    match /users/{userId}/favorites/{articleId} {
      function isValidFavorite(data) {
        return data.keys().hasAll(['articleId', 'title', 'userId', 'createdAt']) &&
               data.articleId is string &&
               data.title is string && data.title.size() <= 500 &&
               data.userId == userId;
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidFavorite(request.resource.data) &&
                      request.resource.data.createdAt == request.time;
                      
      allow delete: if isOwner(userId);
    }
  }
}
