rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isVerifiedUser() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return (data.get('email', '') is string && data.get('email', '').size() <= 128)
          && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 128)
          && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 512)
          && (data.get('preferences', null) == null || (
              data.preferences.get('categories', []) is list 
              && data.preferences.get('categories', []).size() <= 20
          ));
      }

      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt'])
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      
      allow update: if isOwner(userId)
        && isValidUser(incoming())
        && incoming().updatedAt == request.time
        && (
            // Action: Update Profile
            (incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'photoURL', 'email', 'updatedAt'])) ||
            // Action: Update Preferences
            (incoming().diff(existing()).affectedKeys().hasOnly(['preferences', 'updatedAt']))
        )
        && incoming().get('createdAt', existing().createdAt) == existing().createdAt;
    }

    // --- Favorites Subcollection ---
    match /users/{userId}/favorites/{favoriteId} {
      function isValidFavorite(data) {
        return data.keys().hasAll(['articleId', 'title', 'link', 'userId', 'createdAt'])
          && data.userId == request.auth.uid
          && data.articleId is string && data.articleId.size() <= 128
          && data.title is string && data.title.size() <= 1024
          && data.link is string && data.link.size() <= 2048;
      }

      allow list: if isOwner(userId);
      allow get: if isOwner(userId) && isValidId(favoriteId);
      
      allow create: if isOwner(userId) 
        && isValidId(favoriteId)
        && isValidFavorite(incoming())
        && incoming().createdAt == request.time;
        
      allow delete: if isOwner(userId);
    }
  }
}
